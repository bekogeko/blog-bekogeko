---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-border text-sm text-faint">
	<div
		class="mx-auto flex w-[760px] max-w-[calc(100%-2.5rem)] flex-wrap items-center justify-between gap-4 py-7"
	>
		<span>&copy; {year} {SITE_TITLE}</span>
		<div class="flex gap-4">
			<a href="/rss.xml" class="text-faint transition-colors hover:text-foreground">RSS</a>
			<a
				href="https://github.com/"
				target="_blank"
				rel="noopener"
				class="text-faint transition-colors hover:text-foreground"
			>
				GitHub
			</a>
		</div>
	</div>
</footer>
