---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="border-b border-border">
	<nav
		class="mx-auto flex h-[58px] w-[760px] max-w-[calc(100%-2.5rem)] items-center justify-between gap-4 sm:gap-6"
	>
		<a
			href="/"
			class="max-w-[40vw] truncate text-[1.05rem] font-bold tracking-tight text-foreground hover:text-foreground sm:max-w-none"
		>
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-0.5 sm:gap-1">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/tags">Tags</HeaderLink>
			<HeaderLink href="/categories">Categories</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
