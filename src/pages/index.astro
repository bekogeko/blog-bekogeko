---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostList from '../components/PostList.astro';
import Button from '../components/starwind/button/index';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getSortedPosts } from '../utils/taxonomy';

const posts = (await getSortedPosts()).slice(0, 5);
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="mx-auto w-[760px] max-w-[calc(100%-2.5rem)] py-12">
			<section class="mb-14">
				<h1 class="text-[clamp(2rem,5vw,2.75rem)] font-bold tracking-tight">
					{SITE_TITLE}
				</h1>
				<p class="mt-2 max-w-[50ch] text-lg text-muted-foreground">
					{SITE_DESCRIPTION}
				</p>
				<div class="mt-6">
					<Button href="/blog" variant="primary">Read the blog</Button>
				</div>
			</section>

			<section>
				<div class="mb-6 flex items-baseline justify-between">
					<h2
						class="text-sm font-bold uppercase tracking-[0.08em] text-muted-foreground"
					>
						Latest posts
					</h2>
					<a
						href="/blog"
						class="text-sm text-muted-foreground transition-colors hover:text-primary"
					>
						All posts →
					</a>
				</div>
				<PostList posts={posts} />
			</section>
		</main>
		<Footer />
	</body>
</html>
