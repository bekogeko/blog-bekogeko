---
import type { GetStaticPaths } from 'astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostList from '../../components/PostList.astro';
import { SITE_TITLE } from '../../consts';
import {
	getCategories,
	getSortedPosts,
	postsInCategory,
} from '../../utils/taxonomy';

export const getStaticPaths = (async () => {
	const posts = await getSortedPosts();
	const categories = await getCategories(posts);
	return categories.map((cat) => ({
		params: { category: cat.slug },
		props: { category: cat, posts: postsInCategory(posts, cat.slug) },
	}));
}) satisfies GetStaticPaths;

const { category, posts } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead
			title={`${category.name} · ${SITE_TITLE}`}
			description={`Posts in “${category.name}”.`}
		/>
	</head>
	<body>
		<Header />
		<main class="mx-auto w-[760px] max-w-[calc(100%-2.5rem)] py-12">
			<header class="mb-10">
				<a
					href="/categories"
					class="mb-5 inline-block text-sm text-muted-foreground transition-colors hover:text-foreground"
				>
					← All categories
				</a>
				<h1 class="text-[clamp(2rem,5vw,2.75rem)] font-bold tracking-tight">
					{category.name}
				</h1>
				<p class="mt-1 text-muted-foreground">
					{posts.length} {posts.length === 1 ? 'post' : 'posts'}
				</p>
			</header>
			<PostList posts={posts} />
		</main>
		<Footer />
	</body>
</html>
