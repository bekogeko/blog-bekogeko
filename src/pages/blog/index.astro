---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<h1>The Blog</h1>
				<p>Everything I've written, newest first.</p>
			</header>
			<ul class="post-grid">
				{
					posts.map((post) => (
						<li class="card">
							<a href={`/blog/${post.id}/`}>
								<div class="thumb">
									{post.data.heroImage ? (
										<Image
											width={720}
											height={360}
											src={post.data.heroImage}
											alt=""
										/>
									) : (
										<div class="thumb-fallback" aria-hidden="true">
											🌙
										</div>
									)}
								</div>
								<div class="card-body">
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="title">{post.data.title}</h2>
									<p class="excerpt">{post.data.description}</p>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 1100px;
	}
	.page-head {
		margin-bottom: 2.5em;
	}
	.page-head h1 {
		font-size: clamp(2.5rem, 6vw, 3.5rem);
		margin: 0 0 0.2em;
	}
	.page-head p {
		margin: 0;
		color: var(--text-muted);
		font-size: 1.1rem;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.card {
		border: 1px solid var(--border);
		background: var(--bg-elev);
		border-radius: var(--radius);
		overflow: hidden;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}
	.card a {
		display: block;
		color: inherit;
	}
	.card:hover {
		transform: translateY(-4px);
		border-color: var(--border-strong);
		box-shadow: var(--shadow);
	}
	.thumb {
		aspect-ratio: 2 / 1;
		overflow: hidden;
		background: var(--bg-elev-2);
	}
	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
		transition: transform 0.3s ease;
	}
	.card:hover .thumb :global(img) {
		transform: scale(1.04);
	}
	.thumb-fallback {
		width: 100%;
		height: 100%;
		display: grid;
		place-items: center;
		font-size: 2.5rem;
		background:
			radial-gradient(120% 120% at 50% 0%, rgba(139, 140, 255, 0.18), transparent 60%),
			var(--bg-elev-2);
	}
	.card-body {
		padding: 1.1em 1.25em 1.4em;
	}
	.date {
		margin: 0 0 0.4em;
		font-size: 0.85rem;
		color: var(--text-faint);
	}
	.title {
		margin: 0 0 0.4em;
		font-size: 1.3rem;
		color: #f4f5fb;
		line-height: 1.25;
	}
	.card:hover .title {
		color: var(--accent-bright);
	}
	.excerpt {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.95rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 720px) {
		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
