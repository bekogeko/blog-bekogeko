---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostList from '../../components/PostList.astro';
import { SITE_TITLE } from '../../consts';
import { getSortedPosts } from '../../utils/taxonomy';

const posts = await getSortedPosts();
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead
			title={`Blog · ${SITE_TITLE}`}
			description="Everything I've written, newest first."
		/>
	</head>
	<body>
		<Header />
		<main class="mx-auto w-[760px] max-w-[calc(100%-2.5rem)] py-12">
			<header class="mb-10">
				<h1 class="text-[clamp(2rem,5vw,2.75rem)] font-bold tracking-tight">
					Blog
				</h1>
				<p class="mt-1 text-muted-foreground">{posts.length} posts, newest first.</p>
			</header>
			<PostList posts={posts} />
		</main>
		<Footer />
	</body>
</html>
