---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Badge from '../components/starwind/badge/index';
import { slugify } from '../utils/taxonomy';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags = [] } =
	Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>
	<body>
		<Header />
		<main class="mx-auto w-[680px] max-w-[calc(100%-2.5rem)] py-12">
			<article>
				<a
					href="/blog"
					class="mb-8 inline-block text-sm text-muted-foreground transition-colors hover:text-foreground"
				>
					← All posts
				</a>

				<header class="mb-7">
					<div class="flex items-center gap-2 text-sm text-faint">
						<FormattedDate date={pubDate} />
						{
							category && (
								<>
									<span aria-hidden="true">·</span>
									<a
										href={`/categories/${slugify(category)}/`}
										class="text-primary transition-colors hover:text-primary-accent"
									>
										{category}
									</a>
								</>
							)
						}
					</div>
					<h1
						class="mt-2 text-[clamp(2rem,5vw,2.6rem)] font-bold leading-tight tracking-tight"
					>
						{title}
					</h1>
					{
						updatedDate && (
							<p class="mt-2 text-sm italic text-faint">
								Updated <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>

				{
					heroImage && (
						<Image
							class="mb-8 w-full rounded-lg border border-border"
							width={1020}
							height={510}
							src={heroImage}
							alt=""
						/>
					)
				}

				<div class="prose prose-invert max-w-none">
					<slot />
				</div>

				{
					tags.length > 0 && (
						<footer class="mt-12 flex flex-wrap gap-2 border-t border-border pt-6">
							{tags.map((tag) => (
								<Badge
									href={`/tags/${slugify(tag)}/`}
									variant="outline"
									size="sm"
									class="text-muted-foreground hover:text-foreground"
								>
									#{tag}
								</Badge>
							))}
						</footer>
					)
				}
			</article>
		</main>
		<Footer />
	</body>
</html>
